generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = "file:./prisma/users-db.sqlite"
}

model User {
    id                     String            @id @default(cuid())
    username               String            @unique
    email                  String            @unique
    firstname              String
    password               String
    avatarUrl              String            @default("/assets/img/avatar.jpg")
    isOnline               Boolean           @default(false)
    createdAt              DateTime          @default(now())
    // pong stats
    gamesPlayed            Int               @default(0)
    gamesWon               Int               @default(0)
    totalScore             Int               @default(0)
    UserGameHistory        UserGameHistory[]
    sentFriendRequests     Friendship[]      @relation("sent_requests")
    receivedFriendRequests Friendship[]      @relation("received_requests")

    @@map("users")
}

// many to many relationship
model Friendship {
    id        String           @id @default(cuid())
    status    FriendshipStatus @default(PENDING)
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt

    // User who sent the request
    requesterId String
    requester   User   @relation("sent_requests", fields: [requesterId], references: [id], onDelete: Cascade)

    // User who received the request
    receiverId String
    receiver   User   @relation("received_requests", fields: [receiverId], references: [id], onDelete: Cascade)

    @@unique([requesterId, receiverId])
    @@map("friendships")
}

model UserGameHistory {
    id         String   @id @default(cuid())
    userId     String
    gameId     String // id of pong match in pong-db
    isWinner   Boolean
    score      Int
    opponentId String?
    playedAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id])

    @@map("user_game_history")
}

enum FriendshipStatus {
    PENDING
    ACCEPTED
    REJECTED
    BLOCKED
}
