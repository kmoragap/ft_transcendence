generator client {
    provider = "prisma-client-js"
    output   = "../node_modules/.prisma/client"
}

datasource db {
    provider = "sqlite"
    url      = "file:./prisma/pong-db.sqlite"
}

enum GameStatus {
    IN_PROGRESS
    FINISHED
    CANCELLED
}

model Game {
    id     String     @id @default(cuid())
    status GameStatus @default(IN_PROGRESS)

    // Player 1 info
    player1Id   String
    player1Name String
    score1      Int    @default(0)

    // Player 2 info
    player2Id   String
    player2Name String
    score2      Int    @default(0)

    // Game settings
    maxScore     Int     @default(3)
    multiBall    Boolean @default(false)
    mode         String  @default("classic")
    isTournament Boolean @default(false)
    // Winner
    winnerId     String

    // Timestamps
    finishedAt DateTime @default(now())

    @@index([player1Id])
    @@index([player2Id])
    @@index([winnerId])
    @@index([status])
    @@map("games")
}
